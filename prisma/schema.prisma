generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("MAMS_DATABASE_URL")
}

model AgentTaskState {
  taskId       String   @id
  sessionId    String
  parentTaskId String?
  status       String
  version      Int      @default(1)
  state        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([parentTaskId])
}

model AgentCostLedger {
  costScopeId String   @id
  spentUsd    Float    @default(0)
  updatedAt   DateTime @updatedAt
}

model AgentExecutionLog {
  id           String   @id @default(cuid())
  taskId       String
  stepId       String
  agentId      String
  role         String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
}
