generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("MAMS_DATABASE_URL")
  schemas  = ["mams"]
}

model AgentTaskState {
  taskId       String   @id
  sessionId    String
  parentTaskId String?
  status       String
  version      Int      @default(1)
  state        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([parentTaskId])
  @@schema("mams")
}

model AgentCostLedger {
  costScopeId String   @id
  spentUsd    Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@schema("mams")
}

model AgentExecutionLog {
  id           String   @id @default(cuid())
  taskId       String
  stepId       String
  agentId      String
  role         String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
  @@schema("mams")
}

model AgentStepRecord {
  id               String   @id @default(cuid())
  taskId           String
  stepId           String
  stepIndex        Int
  agentId          String
  role             String
  narrativeSummary String
  toolCalls        Json
  usage            Json
  timestampMs      BigInt
  createdAt        DateTime @default(now())

  @@unique([taskId, stepId])
  @@index([taskId, stepIndex])
  @@schema("mams")
}
